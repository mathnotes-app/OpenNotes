{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "src/*"
      ],
      "@mathnotes/mobile-ink": [
        "../mobile-ink/src/index.ts"
      ],
      "@mathnotes/mobile-ink/*": [
        "../mobile-ink/src/*"
      ]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx"
  ]
}
